# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider Configuration
# Copy this file to .env and fill in your credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Select LLM provider: gemini | openai | anthropic
LLM_PROVIDER=gemini

# ── Google Gemini (default) ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash   # Optional: override model name

# ── OpenAI (alternative) ─────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini        # Optional: override model name

# ── Anthropic (alternative) ──────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-5-haiku-latest  # Optional: override model name
